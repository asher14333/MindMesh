# Copy to .env and fill in values
# All vars are prefixed MINDMESH_ per config.py

# Backend URLs that the frontend is allowed to connect from
MINDMESH_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Example deployed value:
# MINDMESH_ALLOWED_ORIGINS=["https://mind-mesh-mu.vercel.app","http://localhost:3000","http://127.0.0.1:3000"]

# Transcript trigger tuning
MINDMESH_PAUSE_THRESHOLD_SECONDS=1.5
MINDMESH_MIN_NEW_CHARS=24
MINDMESH_GENERATION_COOLDOWN_SECONDS=1.0

# LLM integration
# MINDMESH_LLM_API_KEY=sk-...
MINDMESH_LLM_BASE_URL=https://api.openai.com/v1
MINDMESH_LLM_MODEL=gpt-5-mini
MINDMESH_LLM_TIMEOUT_SECONDS=8.0
MINDMESH_LLM_MAX_RETRIES=1
